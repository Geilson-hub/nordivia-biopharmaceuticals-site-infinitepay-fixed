generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}


model User {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  phoneIsWhats Boolean
  email        String   @unique
  cpf          String?  // obrigatório apenas no checkout
  address      String?  // obrigatório apenas no checkout
  marketingOpt Boolean
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       Order[]
  messages     ContactMessage[]
}

model Product {
  id            String  @id @default(cuid())
  slug          String  @unique
  name          String
  concentration String
  brlPrice      Int
  image         String
  leafletPath   String
  orderItems    OrderItem[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status String @default("PENDING")
  totalBrl    Int         // centavos

  // Pagamento (estrutura para PicPay)
paymentProvider String? // ex: "PICPAY"
  paymentUrl      String? // link de checkout gerado
  invoiceSlug     String? // invoice_slug / slug
  transactionNsu  String? // transaction_nsu
  receiptUrl      String? // receipt_url
  captureMethod   String? // pix | credit_card | boleto (quando aplicável)
  paidAmount      Int?    // centavos
  installments    Int?    // número de parcelas (cartão)
  paidAt          DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  unitBrl   Int      // centavos
  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
}



